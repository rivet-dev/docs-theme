---
import BaseLayout from './BaseLayout.astro';
import { Header } from '../components/v2/Header';
import config from 'virtual:rivet-docs/config';
import type { SidebarItem } from '../lib/sitemap';

interface Props {
	title: string;
	description?: string;
	canonicalUrl?: string;
	sidebar?: SidebarItem[];
}

const { title, description, canonicalUrl, sidebar } = Astro.props;
const pathname = Astro.url.pathname;

// The header includes the secondary tab strip ONLY when there are 2+ tabs
// (see DocsTabs). With the strip the chrome is 8.0625rem; without it the header
// is 4.5625rem. --header-height drives the sticky sidebar top + min-h-content,
// so it must match what's actually rendered or the sidebar sits too low.
const hasTabStrip = ((config as { tabs?: unknown[] })?.tabs?.length ?? 0) > 1;
const headerHeight = hasTabStrip ? '8.0625rem' : '4.5625rem';
---

<BaseLayout title={title} description={description} canonicalUrl={canonicalUrl} themeColor="#EFEFEF">
	<Header variant="full-width" showDocsTabs={true} light={true} active="docs" sidebarData={sidebar} initialPathname={pathname} client:load />
	<div class="paper-grain selection-paper w-full relative z-10 font-sans">
		<div class="mx-auto w-full min-h-content flex flex-col md:grid md:grid-cols-docs" style={`--header-height: ${headerHeight};`}>
			<slot />
		</div>
	</div>
	{/* Forward a consumer-provided footer (e.g. the marketing Footer) through to
	    BaseLayout's named footer slot; if none is passed, BaseLayout's default
	    (theme) Footer renders. */}
	<slot name="footer" slot="footer" />
</BaseLayout>

<!-- Docs sit on the porcelain field, matching the marketing pages. The body
     itself is painted so overscroll and short pages never flash the dark
     base. Learn keeps its own dark shell. -->
<style is:global>
	body {
		background-color: #efefef;
	}
</style>
