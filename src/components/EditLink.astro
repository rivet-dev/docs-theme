---
/**
 * Edit-page link — identical to Rivet's (src/pages/docs/[...slug].astro):
 * an outline pill, `border-ink/15 bg-white/55 rounded-md px-3 py-2 text-sm
 * text-ink hover:border-ink/30`, with a faPencil icon in ink-faint.
 */
const { editUrl } = Astro.locals.starlightRoute;
---

{
	editUrl && (
		<a href={editUrl} class="se-edit print:hidden">
			<svg class="se-edit__icon" viewBox="0 0 512 512" fill="currentColor" aria-hidden="true" width="14" height="14">
				<path d="M410.3 231l11.3-11.3-33.9-33.9-62.1-62.1L291.7 89.8l-11.3 11.3-22.6 22.6L58.6 322.9c-10.4 10.4-18 23.3-22.2 37.4L1 480.7c-2.5 8.4-.2 17.5 6.1 23.7s15.3 8.5 23.7 6.1l120.3-35.4c14.1-4.2 27-11.8 37.4-22.2L387.7 253.7 410.3 231zM160 399.4l-9.1 22.7c-4 3.1-8.5 5.4-13.3 6.9L59.4 452l23-78.1c1.4-4.9 3.8-9.4 6.9-13.3l22.7-9.1 0 32c0 8.8 7.2 16 16 16l32 0zM362.7 18.7L348.3 33.2 325.7 55.8 314.3 67.1l33.9 33.9 62.1 62.1 33.9 33.9 11.3-11.3 22.6-22.6 14.5-14.5c25-25 25-65.5 0-90.5L453.3 18.7c-25-25-65.5-25-90.5 0zm-47.4 168l-144 144c-6.2 6.2-16.4 6.2-22.6 0s-6.2-16.4 0-22.6l144-144c6.2-6.2 16.4-6.2 22.6 0s6.2 16.4 0 22.6z" />
			</svg>
			Edit this page
		</a>
	)
}

<style>
	/* Unlayered (not @layer) so it wins over Starlight's layered footer/link
	   reset — matches Rivet's edit-page outline pill. */
	.se-edit {
		display: inline-flex;
		align-items: center;
		gap: 0.5rem;
		border: 1px solid var(--se-hairline-strong);
		background: rgba(255, 255, 255, 0.55);
		border-radius: 0.375rem;
		padding: 0.5rem 0.75rem;
		font-size: 0.875rem;
		color: var(--se-ink);
		text-decoration: none;
		transition: border-color 0.15s;
	}
	.se-edit:hover {
		border-color: rgba(27, 25, 22, 0.3);
	}
	.se-edit__icon {
		color: var(--se-ink-faint);
		flex: none;
	}
</style>
