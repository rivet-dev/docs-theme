---
/**
 * Page title with a pine "eyebrow" naming the parent sidebar section, matching
 * the Rivet docs (e.g. a small "Features" label above the page heading).
 */
const { sidebar, entry } = Astro.locals.starlightRoute;

// The docs overview renders its own centered hero (DocsLanding), so suppress
// the default left-aligned page title there.
const isOverview = entry.slug === "docs" || entry.id === "docs/index.mdx";

function containsCurrent(items) {
	return items.some((item) =>
		item.type === "link"
			? item.isCurrent
			: item.entries && containsCurrent(item.entries),
	);
}

let eyebrow;
for (const item of sidebar) {
	if (item.type === "group" && containsCurrent(item.entries)) {
		eyebrow = item.label;
		break;
	}
}
// Don't echo the eyebrow when it would just duplicate the title.
if (eyebrow && eyebrow === entry.data.title) eyebrow = undefined;
---

{
	isOverview ? (
		<h1 id="_top" class="sr-only">{entry.data.title}</h1>
	) : (
		<div class="se-title-row">
			<div class="se-title-block">
				{eyebrow && <div class="se-eyebrow">{eyebrow}</div>}
				<h1 id="_top">{entry.data.title}</h1>
			</div>
			<div class="se-copy-group">
				<button class="se-copy-md" type="button" aria-label="Copy page as Markdown">
					<svg class="se-copy-md__icon" viewBox="0 0 640 512" fill="currentColor" aria-hidden="true"><path d="M593.8 59.1H46.2C20.7 59.1 0 79.8 0 105.2v301.5c0 25.5 20.7 46.2 46.2 46.2h547.7c25.5 0 46.2-20.7 46.1-46.1V105.2c0-25.4-20.7-46.1-46.2-46.1zM338.5 360.6H277v-120l-61.5 76.9-61.5-76.9v120H92.3V151.4h61.5l61.5 76.9 61.5-76.9h61.5v209.2zm135.3 3.1L381.5 256H443V151.4h61.5V256H566z"/></svg>
