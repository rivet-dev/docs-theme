}

<script is:inline>
	(() => {
		const btn = document.querySelector(".se-copy-md");
		if (!btn) return;
		const label = btn.querySelector(".se-copy-md__label");
		const serialize = (root) => {
			const out = [];
			const h1 = document.querySelector("h1#_top");
			if (h1) out.push("# " + h1.textContent.trim());
			root.querySelectorAll(":scope > *").forEach((el) => {
				const tag = el.tagName.toLowerCase();
				if (/^h[1-6]$/.test(tag)) out.push("#".repeat(+tag[1]) + " " + el.textContent.trim());
				else if (tag === "pre") out.push("```\n" + el.textContent.replace(/\n+$/, "") + "\n```");
				else if (tag === "ul" || tag === "ol")
					el.querySelectorAll(":scope > li").forEach((li) => out.push("- " + li.textContent.trim().replace(/\s+/g, " ")));
				else {
					const t = el.textContent.trim().replace(/\s+/g, " ");
					if (t) out.push(t);
				}
			});
			return out.join("\n\n");
		};
		const copy = async (text, flash) => {
			try {
				await navigator.clipboard.writeText(text);
				if (flash && label) {
					label.textContent = "Copied!";
					setTimeout(() => label && (label.textContent = "Copy Markdown"), 1600);
				}
			} catch {}
		};
		btn.addEventListener("click", () =>
			copy(serialize(document.querySelector(".sl-markdown-content") || document.body), true),
		);
		const caret = document.querySelector(".se-copy-caret");
		const menu = document.querySelector(".se-copy-menu");
		if (caret && menu) {
			const close = () => { menu.hidden = true; caret.setAttribute("aria-expanded", "false"); };
			caret.addEventListener("click", (e) => {
				e.stopPropagation();
				const open = menu.hidden;
				menu.hidden = !open;
				caret.setAttribute("aria-expanded", String(open));
			});
			document.addEventListener("click", close);
			menu.querySelectorAll("[data-act]").forEach((item) =>
				item.addEventListener("click", () => {
					const md = serialize(document.querySelector(".sl-markdown-content") || document.body);
					const act = item.getAttribute("data-act");
					if (act === "link") {
						copy(location.href, false);
					} else if (act === "view") {
						const blob = new Blob([md], { type: "text/markdown" });
						window.open(URL.createObjectURL(blob), "_blank");
					} else if (act === "chatgpt") {
						const q = encodeURIComponent(`Read this document so I can ask questions about it: ${location.href}`);
						window.open(`https://chat.openai.com/?q=${q}`, "_blank");
					} else if (act === "claude") {
						const q = encodeURIComponent(`Read this document so I can ask questions about it: ${location.href}`);
						window.open(`https://claude.ai/new?q=${q}`, "_blank");
					}
					close();
				}),
			);
		}
	})();
</script>

<style>
	@layer starlight.core {
		.se-title-row {
			display: flex;
			align-items: flex-start;
			justify-content: space-between;
			gap: 1rem;
		}
		/* Verbatim Rivet "Copy Markdown" split button (DocsPageDropdown): a main
		   button (markdown icon + label, rounded-l, no right border) + a chevron
		   button (rounded-r, left border). h-8, ink/15 border, white/55, text-ink,
		   hover ink/30 + white/70. */
		.se-copy-group {
			flex: none;
			position: relative;
			display: inline-flex;
			margin-top: 0.6rem;
		}
		.se-copy-md,
		.se-copy-caret {
			display: inline-flex;
			align-items: center;
			height: 32px;
			border: 1px solid var(--se-hairline-strong);
			background: rgba(255, 255, 255, 0.55);
			color: var(--se-ink);
			font-size: 14px;
			font-weight: 500;
			cursor: pointer;
			transition: border-color 0.15s, background 0.15s;
		}
		.se-copy-md {
			gap: 4px;
			padding: 0 12px;
			border-radius: 6px 0 0 6px;
			border-right: 0;
			white-space: nowrap;
		}
		.se-copy-md__icon {
			height: 1rem;
			width: auto;
		}
		.se-copy-caret {
			justify-content: center;
			width: 32px;
			padding: 0;
			border-radius: 0 6px 6px 0;
		}
		.se-copy-caret svg {
			width: 12px;
			height: 12px;
		}
		.se-copy-md:hover,
		.se-copy-caret:hover {
			border-color: rgba(27, 25, 22, 0.3);
			background: rgba(255, 255, 255, 0.7);
		}
		.se-copy-menu[hidden] {
			display: none;
		}
		.se-copy-menu {
			position: absolute;
			top: calc(100% + 6px);
			inset-inline-end: 0;
			z-index: 30;
			min-width: 14rem;
			display: flex;
			flex-direction: column;
			padding: 0.25rem;
			background: #ffffff;
			border: 1px solid var(--se-hairline);
			border-radius: 0.5rem;
			box-shadow: 0 8px 24px rgba(27, 25, 22, 0.12);
		}
		.se-copy-menu button {
			display: flex;
			align-items: center;
			gap: 0.5rem;
			text-align: start;
			padding: 0.4rem 0.5rem;
			border: 0;
			background: transparent;
			border-radius: 0.375rem;
			color: var(--se-ink);
			font-size: 0.875rem;
			cursor: pointer;
		}
		.se-copy-menu button:hover {
			background: rgba(27, 25, 22, 0.06);
		}
		.se-copy-menu__ic {
			width: 1rem;
			height: 1rem;
			flex: none;
			color: var(--se-ink-soft);
		}
		.se-copy-menu__ext {
			width: 0.75rem;
			height: 0.75rem;
			flex: none;
			margin-inline-start: auto;
			opacity: 0.6;
		}
		.se-eyebrow {
			font-size: 0.875rem;
			font-weight: 600;
			color: var(--se-pine);
			margin-top: 0;
			margin-bottom: 0.25rem;
		}
		h1.sr-only {
			position: absolute;
			width: 1px;
			height: 1px;
			padding: 0;
			margin: -1px;
			overflow: hidden;
			clip: rect(0, 0, 0, 0);
			white-space: nowrap;
			border: 0;
		}
		h1:not(.sr-only) {
			margin-top: 0.25rem;
			font-size: 2.25rem; /* 36px — Rivet */
			line-height: 2.5rem; /* 40px */
			font-weight: 500;
			letter-spacing: -0.025em;
			color: var(--sl-color-white);
		}
		/* When an eyebrow precedes the title, keep the top spacing tight. */
		.se-eyebrow + h1 {
			margin-top: 0.25rem;
		}
	}
</style>
