---
/**
 * Porcelain docs header — the Rivet docs header chrome (rivet.dev/docs). The
 * "[Rivet mark] | [product]" lockup is the shared Rivet sub-brand lockup. All
 * project-specific data (product wordmark, nav, social, CTA, repo) comes from
 * the SiteConfig via the `virtual:rivet-docs/config` module; nothing here is
 * hardcoded to a single project.
 */
import Search from '@astrojs/starlight/components/Search.astro';
import GitHubStars from './GitHubStars.astro';
import config from 'virtual:rivet-docs/config';

const pathname = Astro.url.pathname;
const isCurrent = (match?: string) =>
	match ? pathname === match || pathname.startsWith(match.endsWith('/') ? match : match + '/') || pathname === match : false;

const topNav = config.topNav ?? [];
const discord = config.social?.discord;
const repo = config.repo;
const cta = config.cta;
---

<div class="se-header">
	<div class="se-header__row1">
	<div class="se-header__left">
		<a href="https://rivet.dev" class="se-logo-rivet" aria-label="Rivet">
			<svg width="28" height="28" viewBox="0 0 128 128" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
				<rect x="1" y="1" width="126" height="126" rx="44" fill="#0F0F0F"/>
				<rect x="18.25" y="18.25" width="91.5" height="91.5" rx="25.75" stroke="#F0F0F0" stroke-width="8.5"/>
				<path fill-rule="evenodd" clip-rule="evenodd" d="M57.694 43.098c0-.622-.505-1.126-1.127-1.126h-8.444a5.114 5.114 0 0 0-5.112 5.111v33.824a5.114 5.114 0 0 0 5.112 5.112h8.444c.622 0 1.127-.505 1.127-1.127V43.098Zm24.424 27.869c-1.238-2.222-4.047-4.026-6.27-4.026H62.923c-.684 0-.93.555-.549 1.239l7.703 13.822c1.239 2.223 4.048 4.026 6.27 4.026h12.927c.683 0 .93-.555.548-1.239l-7.703-13.822Zm.538-18.718c0-5.672-4.605-10.277-10.277-10.277H63.31a1.21 1.21 0 0 0-1.209 1.209v18.137c0 .667.542 1.209 1.21 1.209h9.068c5.672 0 10.277-4.605 10.277-10.278Z" fill="#F0F0F0"/>
			</svg>
		</a>
		<span class="se-logo-divider" aria-hidden="true"></span>
		<a href={config.productHome} class="se-logo-se" aria-label={`${config.product} home`}>
			{config.productLogo ? (
				<img src={config.productLogo} alt={config.product} />
			) : (
				<span class="se-logo-text">{config.product}</span>
			)}
		</a>
		{topNav.length > 0 && (
			<nav class="se-nav sl-hidden md:sl-flex" aria-label="Primary">
				{topNav.map((item) => (
					<a href={item.href} aria-current={isCurrent(item.match) ? 'page' : undefined}>{item.label}</a>
				))}
			</nav>
		)}
	</div>

	<div class="se-header__right">
		<div class="se-search print:hidden"><Search /></div>
		{discord && (
			<a
				class="se-discord sl-hidden md:sl-flex"
				href={discord}
				aria-label="Discord"
			>
				<svg viewBox="0 0 24 24" fill="currentColor" width="18" height="18" aria-hidden="true">
					<path d="M20.317 4.37a19.791 19.791 0 0 0-4.885-1.515.074.074 0 0 0-.079.037c-.21.375-.444.864-.608 1.25a18.27 18.27 0 0 0-5.487 0 12.64 12.64 0 0 0-.617-1.25.077.077 0 0 0-.079-.037A19.736 19.736 0 0 0 3.677 4.37a.07.07 0 0 0-.032.027C.533 9.046-.32 13.58.099 18.057a.082.082 0 0 0 .031.057 19.9 19.9 0 0 0 5.993 3.03.078.078 0 0 0 .084-.028c.462-.63.874-1.295 1.226-1.994a.076.076 0 0 0-.041-.106 13.107 13.107 0 0 1-1.872-.892.077.077 0 0 1-.008-.128 10.2 10.2 0 0 0 .372-.292.074.074 0 0 1 .077-.01c3.928 1.793 8.18 1.793 12.062 0a.074.074 0 0 1 .078.01c.12.098.246.198.373.292a.077.077 0 0 1-.006.127 12.299 12.299 0 0 1-1.873.892.077.077 0 0 0-.041.107c.36.698.772 1.362 1.225 1.993a.076.076 0 0 0 .084.028 19.839 19.839 0 0 0 6.002-3.03.077.077 0 0 0 .032-.054c.5-5.177-.838-9.674-3.549-13.66a.061.061 0 0 0-.031-.03zM8.02 15.33c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.956-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.956 2.418-2.157 2.418zm7.975 0c-1.183 0-2.157-1.085-2.157-2.419 0-1.333.955-2.419 2.157-2.419 1.21 0 2.176 1.096 2.157 2.42 0 1.333-.946 2.418-2.157 2.418z"></path>
				</svg>
			</a>
		)}
		{repo && (
			<GitHubStars repo={repo} class="se-github sl-hidden md:sl-flex" />
		)}
		{cta && (
			<a class="se-cta sl-hidden md:sl-flex" href={cta.href}>{cta.label}</a>
		)}
	</div>
	</div>
</div>

<style>
	.se-header {
		display: flex;
		flex-direction: column;
		height: 100%;
		width: 100%;
		font-family: var(--sl-font);
	}
	.se-header__row1 {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 1rem;
		flex: 1;
		min-height: 3.25rem;
	}
	.se-header__left {
		display: flex;
		align-items: center;
		gap: 0.75rem;
		min-width: 0;
	}
	.se-header__right {
		display: flex;
		align-items: center;
		gap: 0.5rem;
	}
	.se-logo-rivet {
		display: flex;
		align-items: center;
	}
	.se-logo-rivet svg {
		width: 28px;
		height: 28px;
		border-radius: 7px;
	}
	.se-logo-divider {
		width: 1px;
		height: 20px;
		background: rgba(27, 25, 22, 0.2);
	}
	.se-logo-se {
		display: flex;
		align-items: center;
		text-decoration: none;
	}
	.se-logo-se img {
		height: 18px;
		width: auto;
	}
	.se-logo-text {
		font-size: 1.0625rem;
		font-weight: 600;
		letter-spacing: -0.01em;
		color: var(--se-ink);
	}
	.se-nav {
		align-items: center;
		gap: 1.25rem; /* 20px between items — Rivet */
		margin-inline-start: 1.5rem;
	}
	/* Rivet nav links are plain medium-weight text (no button padding/pill). */
	.se-nav a {
		padding: 0;
		font-size: 0.875rem;
		font-weight: 500;
		color: var(--se-ink-soft);
		text-decoration: none;
		transition: color 0.15s;
	}
	.se-nav a:hover {
		color: var(--se-ink);
	}
	.se-nav a[aria-current='page'] {
		color: var(--se-ink);
	}
	.se-discord {
		align-items: center;
		justify-content: center;
		width: 2.25rem;
		height: 2.25rem;
		color: var(--se-ink-soft);
		border-radius: 0.375rem;
		transition: color 0.15s;
	}
	.se-discord:hover {
		color: var(--se-ink);
	}
	.se-cta {
		align-items: center;
		justify-content: center;
		white-space: nowrap;
		border-radius: 0.375rem;
		background: var(--se-ink);
		color: var(--se-cream);
		padding: 0.45rem 0.95rem;
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		transition: background 0.15s;
	}
	.se-cta:hover {
		background: rgba(27, 25, 22, 0.85);
	}
</style>

<style is:global>
	/* GitHub stars button — porcelain outline pill. */
	.se-github {
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
		white-space: nowrap;
		border-radius: 0.375rem;
		border: 1px solid var(--se-hairline-strong);
		color: var(--se-ink-soft);
		padding: 0.5rem 1rem;
		height: 2.5rem; /* 40px — matches Rivet */
		font-size: 0.875rem;
		font-weight: 500;
		text-decoration: none;
		transition: color 0.15s, border-color 0.15s;
	}
	.se-github svg {
		width: 1rem;
		height: 1rem;
		flex: none;
	}
	.se-github:hover {
		color: var(--se-ink);
		border-color: rgba(27, 25, 22, 0.3);
	}

	/* Search trigger — verbatim Rivet: 32px tall pill, white/0.6, ink/15 border,
	   8px radius. */
	.se-search :is(button, .sl-link-button) {
		height: 2rem;
		background: rgba(255, 255, 255, 0.6);
		border: 1px solid var(--se-hairline-strong);
		color: var(--se-ink-faint);
		border-radius: 0.5rem;
	}
	.se-search :is(button, .sl-link-button):hover {
		border-color: rgba(27, 25, 22, 0.3);
		color: var(--se-ink-soft);
	}
	/* Shortcut badge. Starlight nests <kbd><kbd>Ctrl</kbd><kbd>K</kbd></kbd>, so
	   styling every kbd produced nested rounded rects. Make ONLY the wrapper the
	   badge, strip the inner keys' boxes, and hide the modifier so it reads "K"
	   like Rivet. */
	.se-search kbd {
		background: rgba(27, 25, 22, 0.06);
		border: 1px solid rgba(27, 25, 22, 0.2);
		border-radius: 4px;
		color: var(--se-ink-faint);
	}
	.se-search kbd kbd {
		background: transparent;
		border: 0;
		border-radius: 0;
		padding: 0;
	}
	.se-search kbd kbd:first-child {
		display: none;
	}

	/* Header bar: porcelain glass with hairline + blur. */
	@layer starlight.core {
		.page > .header {
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			/* Row 1 (flex:1) + the 56px tab row fill the 129px header with no
			   extra padding, matching Rivet's two-row proportions. */
			padding-block: 0;
		}
	}
</style>
