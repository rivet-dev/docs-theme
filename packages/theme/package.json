{
  "name": "@rivet-dev/docs-theme",
  "version": "0.2.2",
  "description": "Shared Starlight docs theme and framework for Rivet OSS projects.",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/site-config.d.ts",
