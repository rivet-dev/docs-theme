---
import '../styles/main.css';
import '@fortawesome/fontawesome-svg-core/styles.css';
import { ViewTransitions } from 'astro:transitions';
import { EmbedDetector } from '../components/EmbedDetector';
import { Footer } from '../components/Footer';
import { Providers } from '../components/Providers';
import { TooltipProvider } from '@rivet-gg/components';
import CopyCodeScript from '../components/CopyCodeScript.astro';
import TabsScript from '../components/TabsScript.astro';
import MermaidScript from '../components/MermaidScript.astro';
import config from 'virtual:rivet-docs/config';

interface Props {
	title: string;
	description?: string;
	canonicalUrl?: string;
	ogImage?: string;
	ogType?: string;
	publishedTime?: string;
	keywords?: string[];
	articleAuthor?: string;
	articleSection?: string;
	robots?: string;
	themeColor?: string;
}

// Branding is supplied by the consumer's docs.config (exposed via the
// `virtual:rivet-docs/config` module). Everything that used to be hardcoded to
// rivet.dev now reads from here, with neutral fallbacks.
const site = (config as any) ?? {};
const productName: string = site.product ?? 'Docs';
const siteUrl: string = import.meta.env.PUBLIC_SITE_URL || site.siteUrl || '';
const social = site.social ?? {};
const analytics = site.analytics ?? {};
const favicon = site.favicon ?? {};
const org = site.organization ?? {};

const {
	title,
	description = site.description ?? '',
	canonicalUrl,
	ogImage = site.ogImage,
	ogType = "website",
	publishedTime,
	keywords,
	articleAuthor,
	articleSection,
	robots,
	themeColor = site.themeColor ?? "#EFEFEF",
} = Astro.props;

// Append " - <product>" unless the title already ends with it.
const suffix = ` - ${productName}`;
const formattedTitle = !title
	? productName
	: title.endsWith(suffix) || title === productName
		? title
		: `${title}${suffix}`;

const absoluteOgImage = ogImage
	? (ogImage.startsWith('http') ? ogImage : `${siteUrl}${ogImage}`)
	: undefined;

const ensureTrailingSlash = (path: string): string => {
	if (path.endsWith('/')) return path;
	const lastSegment = path.slice(path.lastIndexOf('/') + 1);
	return lastSegment.includes('.') ? path : `${path}/`;
};

const currentPath = Astro.url.pathname;
const effectiveCanonicalUrl = canonicalUrl
	|| (siteUrl ? `${siteUrl}${ensureTrailingSlash(currentPath)}` : undefined);

const jsonLd = {
	"@context": "https://schema.org",
	"@graph": [
		{
			"@type": "Organization",
			"@id": `${siteUrl}/#organization`,
			"name": org.name ?? productName,
			"url": siteUrl || undefined,
			...(org.logo ? { "logo": { "@type": "ImageObject", "url": org.logo } } : {}),
			...(org.sameAs ? { "sameAs": org.sameAs } : {}),
			...(org.email ? { "contactPoint": { "@type": "ContactPoint", "contactType": "customer support", "email": org.email } } : {}),
		},
		{
			"@type": "WebSite",
			"@id": `${siteUrl}/#website`,
			"url": siteUrl || undefined,
			"name": productName,
			"publisher": { "@id": `${siteUrl}/#organization` },
		},
	],
};
---

<!DOCTYPE html>
<html lang="en" class="dark">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>{formattedTitle}</title>
		{description && <meta name="description" content={description} />}
		{robots && <meta name="robots" content={robots} />}

		{effectiveCanonicalUrl && <link rel="canonical" href={effectiveCanonicalUrl} />}

		<!-- Twitter -->
		{social.twitter && <meta name="twitter:site" content={social.twitter} />}
		<meta name="twitter:card" content="summary_large_image" />
		<meta name="twitter:title" content={formattedTitle} />
		{description && <meta name="twitter:description" content={description} />}
		{absoluteOgImage && <meta name="twitter:image" content={absoluteOgImage} />}

		<!-- Open Graph -->
		<meta property="og:type" content={ogType} />
		<meta property="og:locale" content="en_US" />
		{effectiveCanonicalUrl && <meta property="og:url" content={effectiveCanonicalUrl} />}
		<meta property="og:site_name" content={productName} />
		<meta property="og:title" content={formattedTitle} />
		{description && <meta property="og:description" content={description} />}
		{absoluteOgImage && <meta property="og:image" content={absoluteOgImage} />}
		{absoluteOgImage && <meta property="og:image:alt" content={formattedTitle} />}
		{publishedTime && <meta property="article:published_time" content={publishedTime} />}
		{articleAuthor && <meta property="article:author" content={articleAuthor} />}
		{articleSection && <meta property="article:section" content={articleSection} />}
		{Array.isArray(keywords) && keywords.map((keyword) => <meta property="article:tag" content={keyword.toLowerCase()} />)}

		{siteUrl && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}

		<!-- Self-hosted variable fonts; consumers serve them from /fonts. -->
		<link rel="preload" href="/fonts/manrope/Manrope-Variable-latin.woff2" as="font" type="font/woff2" crossorigin />
		<link rel="preload" href="/fonts/jetbrains-mono/JetBrainsMono-Variable-latin.woff2" as="font" type="font/woff2" crossorigin />
		<slot name="head-fonts" />

		<!-- Favicons (optional, from config.favicon) -->
		{favicon.appleTouchIcon && <link rel="apple-touch-icon" sizes="180x180" href={favicon.appleTouchIcon} />}
		{favicon.icon32 && <link rel="icon" type="image/png" sizes="32x32" href={favicon.icon32} />}
		{favicon.icon16 && <link rel="icon" type="image/png" sizes="16x16" href={favicon.icon16} />}
		{favicon.svg && <link rel="icon" type="image/svg+xml" href={favicon.svg} />}
		{favicon.manifest && <link rel="manifest" href={favicon.manifest} />}
		<meta name="msapplication-TileColor" content={themeColor} />
		<meta name="theme-color" content={themeColor} />

		<!-- Analytics (optional, from config.analytics) -->
		{analytics.ahrefsKey && <script is:inline async src="https://analytics.ahrefs.com/analytics.js" data-key={analytics.ahrefsKey}></script>}
		{analytics.gaId && (
			<>
				<script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${analytics.gaId}`}></script>
				<script is:inline set:html={`window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','${analytics.gaId}');`}></script>
			</>
		)}

		<ViewTransitions />
	</head>
	<body class="dark">
		<a href="#main-content" class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-50 focus:px-4 focus:py-2 focus:bg-white focus:text-black focus:rounded-md focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-white">
			Skip to main content
		</a>
		<TooltipProvider client:load>
			<Providers client:load>
				<slot />
			</Providers>
		</TooltipProvider>
		<EmbedDetector client:load />
		<slot name="footer"><Footer client:load initialPathname={Astro.url.pathname} /></slot>
		<CopyCodeScript />
		<TabsScript />
		<MermaidScript />
	</body>
</html>
