---
import DocsLayout from "@rivet-dev/docs-theme/layouts/DocsLayout.astro";
import * as mdxComponents from "@rivet-dev/docs-theme/components/mdx.jsx";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((entry) => ({
    params: { slug: entry.id === "index" ? undefined : entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);
---

<DocsLayout title={entry.data.title} description={entry.data.description}>
  <article class="prose mx-auto max-w-3xl px-6 py-10" id="main-content">
    <h1>{entry.data.title}</h1>
    <Content components={mdxComponents} />
  </article>
</DocsLayout>
